{
  "manifest_version": 3,
  "name": "Clarity",
  "version": "0.1",
  "description": "Blur unwanted words on webpages",

  "permissions": ["storage"],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon64.png",
    "128": "icons/icon64.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}