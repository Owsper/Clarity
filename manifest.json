{
  "manifest_version": 3,
  "name": "Clarity",
  "version": "0.1",
  "description": "AI-powered browser extension for cleaner social media feeds",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.youtube.com/*",
        "*://*.facebook.com/*"
      ],
      "js": ["script.js"]
    }
  ]
}